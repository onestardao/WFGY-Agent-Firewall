{
  "version": "1.0",
  "rules": {
    "deny": {
      "description": "Hard block. No human review, immediate reject.",
      "patterns": [
        "rm -rf",
        "rm -r",
        "rm -f",
        "find / -delete",
        "find . -delete",
        "mkfs",
        "mkfs.ext",
        "mkfs.vfat",
        "dd if=/dev/zero",
        "dd if=/dev/null",
        "shred",
        "wipefs",
        ":(){ :|:& };:",
        "chmod 777 /etc",
        "chmod 777 /usr",
        "chown -R root",
        "python -c \"import os; os.remove",
        "python3 -c \"import os; os.remove",
        "node -e \"require('fs').rm",
        "node -e \"require('fs').unlink",
        "eval(",
        "exec(",
        "subprocess.call",
        "subprocess.run",
        "os.system("
      ],
      "paths": [
        "/etc",
        "/usr",
        "/var",
        "/bin",
        "/sbin",
        "/boot",
        "/sys",
        "/proc",
        "~"
      ]
    },
    "secret": {
      "description": "Any attempt to read these files or directories triggers DENY.",
      "filenames": [
        ".env",
        ".env.local",
        ".env.production",
        ".env.development",
        "id_rsa",
        "id_ed25519",
        "id_ecdsa",
        "id_dsa",
        "known_hosts",
        ".netrc",
        ".pgpass",
        "credentials",
        "token",
        "secret",
        "private_key",
        "serviceAccountKey.json",
        "client_secret.json",
        "Cookies",
        "Login Data",
        "keystore.jks",
        ".htpasswd",
        "shadow",
        "passwd"
      ],
      "directories": [
        "~/.ssh",
        "~/.aws",
        "~/.gcp",
        "~/.config/gcloud",
        "~/.azure",
        "~/.kube",
        "~/.gnupg",
        "~/.docker",
        "/etc/shadow",
        "/etc/passwd"
      ]
    },
    "review": {
      "description": "Pause and ask human. Not necessarily dangerous, but needs confirmation.",
      "patterns": [
        "curl",
        "wget",
        "nc ",
        "netcat",
        "ssh ",
        "scp ",
        "rsync",
        "git push",
        "git clone",
        "npm publish",
        "pip upload",
        "twine upload",
        "docker push",
        "aws s3 cp",
        "gsutil cp",
        "az storage blob upload",
        "crontab",
        "launchctl",
        "systemctl enable",
        "systemctl start",
        "chmod ",
        "chown ",
        "sudo ",
        "su -"
      ]
    }
  }
}
